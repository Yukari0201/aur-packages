{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)PKGBUILD$/"
      ],
      "matchStrings": [
        "(?:pkgver|_pkgver|_beta_pkgver)=(?<currentValue>.*) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["reF1nd/sing-box-releases"],
      "matchCurrentValue": "/-(alpha|beta|rc)/",
      "ignoreUnstable": false,
      "allowedVersions": "/-(alpha|beta|rc)/"
    },
    {
      "matchDepNames": ["reF1nd/sing-box-releases"],
      "matchCurrentValue": "/^\\d+\\.\\d+\\.\\d+(-reF1nd)?(\\.\\d+)?$/",
      "ignoreUnstable": true
    }
  ]
}
