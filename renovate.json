{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)PKGBUILD$/"],
      "matchStrings": [
        "(?:pkgver|_pkgver)=(?<currentValue>.*) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)PKGBUILD$/"],
      "matchStrings": [
        "(?:_pkgver_stable)=(?<currentValue>\\d+\\.\\d+\\.\\d+)(?:-reF1nd)?(?<revision>\\.\\d+)? # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ],
      "extractVersionTemplate": "^v?(?<version>\\d+\\.\\d+\\.\\d+)(?:-reF1nd)?(?<revision>\\.\\d+)?$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)PKGBUILD$/"],
      "matchStrings": [
        "(?:_pkgver_beta)=(?<currentValue>\\d+\\.\\d+\\.\\d+-(?:alpha|beta|rc)\\.\\d+(?:\\.\\d+)?)(?:-reF1nd)?(?<revision>\\.\\d+)? # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ],
      "extractVersionTemplate": "^v?(?<version>\\d+\\.\\d+\\.\\d+-(?:alpha|beta|rc)\\.\\d+(?:\\.\\d+)?)(?:-reF1nd)?(?<revision>\\.\\d+)?$"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["reF1nd/sing-box-releases"],
      "groupName": "sing-box reF1nd stable",
      "ignoreUnstable": true,
      "versioning": "semver"
    },
    {
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["reF1nd/sing-box-releases"],
      "groupName": "sing-box reF1nd beta",
      "ignoreUnstable": false,
      "versioning": "semver"
    },
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["Yukari0201/fcitx5-pinyin-mihoyo"],
      "groupName": "Fcitx5 pinyin mihoyo"
    },
    {
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["Yukari0201/fcitx5-pinyin-mihoyo"],
      "groupName": "Rime pinyin mihoyo"
    }
  ]
}
