{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)PKGBUILD$/"],
      "matchStrings": [
        "(?:pkgver|_pkgver)=(?<currentValue>.*) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)PKGBUILD$/"],
      "matchStrings": [
        "(?:_pkgver_stable)=(?<currentValue>[^#\\s]+) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)PKGBUILD$/"],
      "matchStrings": [
        "(?:_pkgver_beta)=(?<currentValue>[^#\\s]+) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["reF1nd/sing-box-releases"],
      "groupName": "sing-box reF1nd stable",
      "ignoreUnstable": true,
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-reF1nd(?:\\.(?<build>\\d+))?$"
    },
    {
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["reF1nd/sing-box-releases"],
      "groupName": "sing-box reF1nd beta",
      "ignoreUnstable": false,
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<prerelease>alpha|beta|rc)\\.(?<compatibility>\\d+)-reF1nd(?:\\.(?<build>\\d+))?$"
    },
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["Yukari0201/fcitx5-pinyin-mihoyo"],
      "groupName": "Fcitx5 pinyin mihoyo"
    },
    {
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["Yukari0201/fcitx5-pinyin-mihoyo"],
      "groupName": "Rime pinyin mihoyo"
    }
  ]
}
