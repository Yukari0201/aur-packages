{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)PKGBUILD$/"
      ],
      "matchStrings": [
        "(?:pkgver|_pkgver|_beta_pkgver)=(?<currentValue>.*) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["reF1nd/sing-box-releases"],
      "matchStrings": ["_beta_pkgver=.*"],
      "ignoreUnstable": false,
      "allowedVersions": "/^v?\\d+\\.\\d+\\.\\d+-(alpha|beta|rc)/i"
    },
    {
      "matchPackageNames": ["reF1nd/sing-box-releases"],
      "matchStrings": ["_pkgver=.*"],
      "ignoreUnstable": true,
      "allowedVersions": "/^v?\\d+\\.\\d+\\.\\d+(-reF1nd)?(\\.\\d+)?$/"
    }
  ]
}
